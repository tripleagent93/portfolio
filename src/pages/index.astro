---
import Layout from '~/layouts/PageLayout.astro';

import ContactUs from '~/components/widgets/Contact.astro';
import Content from '~/components/widgets/Content.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import HeroImage from '../assets/images/headshot.jpg';
import PhoneMockupImage from '../assets/images/phone-mockup.png';
import EugeneAvatar from '../assets/images/eugene-avatar.png';
import ErvinAvatar from '../assets/images/Ervin-McWilson.png';
import DavidAvatar from '../assets/images/david-k.png';
import IliyaAvatar from '../assets/images/Iliya-Z.png';
import MikeAvatar from '../assets/images/mike-r.png';
import DanAvatar from '../assets/images/dan-s.png';

const metadata = {
  title: 'Max Otkidychev Portfolio Site',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero
    id="hero"
    title="Max Otkidychev"
    tagline="UX ENGINEER & FRONTEND DEVELOPER"
    actions={[{ variant: 'primary', text: 'View My Work', href: '#portfolio' }]}
  >
    <Fragment slot="subtitle">
      I build scalable React applications with the precision of an engineer and the mindset of a UX designer. With 6+
      years in frontend development and a Google UX Design certification, I create responsive, accessible, and intuitive
      digital experiences that connect product strategy, design systems, and clean engineering.
    </Fragment>
  </Hero>
  <!-- Content Widget **************** -->

  <Content
    id="about"
    columns={3}
    items={[
      {
        icon: 'tabler:brand-figma',
        callToAction: {
          target: '_blank',
          text: 'Figma',
          href: 'https://www.figma.com/design/8C149Ck2shVdm5d5HKkt7c/CreditWise?node-id=141-24&t=F3qBTpq6pE3ukny1-1',
        },
      },
      {
        icon: 'tabler:brand-github',
        callToAction: {
          target: '_blank',
          text: 'Github',
          href: 'https://github.com/tripleagent93/',
        },
      },
      {
        icon: 'tabler:brand-linkedin',
        callToAction: {
          target: '_blank',
          text: 'LinkedIn',
          href: 'https://www.linkedin.com/in/max-otk/',
        },
      },
    ]}
    image={{
      src: HeroImage,
      alt: 'Colorful Image',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">About me</h2>
      <p>
        I’ve always been drawn to both the technical and creative sides of building products. Over the course of my
        career, I’ve worked in frontend engineering developing responsive web applications while also growing my skills
        in UX design, research, and interaction design. Today, I specialize in bridging the gap between design and
        development — turning product ideas and design systems into polished, accessible, production-ready experiences
        using React and modern frontend technologies. I enjoy solving complex UI challenges, collaborating with
        cross-functional teams, and creating interfaces that feel intuitive, fast, and visually refined.
      </p>
      <br />
      <br />
      <p>If you're curious to see how I connect design thinking with development, you can follow my work:</p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="resume"
    title="Work experience"
    items={[
      {
        title:
          'Software Engineer <br /> <span class="font-normal">RSI, Roseville, CA</span> <br /> <span class="text-sm font-normal">2018 - Present</span>',
        description: `Developed and maintained scalable React-based internal applications used by enterprise clients
Collaborated with designers and stakeholders to translate complex workflows into intuitive interfaces
Built reusable UI components and responsive layouts to improve development efficiency
Improved accessibility and usability across core application flows
Worked closely with backend engineers to integrate REST APIs and dynamic state management`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Front-End Developer <br /> <span class="font-normal">ASDcom, Sacramento, CA</span> <br /> <span class="text-sm font-normal">2017 - 2018</span>',
        description: `Developed responsive frontend interfaces using Vue.js
Converted Figma and Adobe XD designs into production-ready UI
Optimized websites for performance, responsiveness, and cross-browser compatibility
Collaborated with designers and developers in an agile environment`,
        icon: 'tabler:briefcase',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    id="resume"
    title="Education"
    items={[
      {
        title: `Google UX Design Professional Certificate</span> <br /> <span class="text-sm font-normal">2025 - 2026</span>`,
        description: `Focus on user research, wireframing, prototyping, and usability testing.`,
        icon: 'tabler:brand-google',
      },
      {
        title: `B.S. in Computer Science<br /> <span class="font-normal">California State University, Sacramento</span> <br /> <span class="text-sm font-normal">2014 - 2017</span>`,
        icon: 'tabler:school',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Skills"
    subtitle="I work at the intersection of UX design and frontend engineering. These are the core skills I use to translate product ideas into scalable, accessible, and production-ready interfaces."
    columns={3}
    defaultIcon="tabler:point-filled"
    items={[
      {
        title: 'Frontend Engineering',
        description:
          'Building scalable, responsive interfaces using modern frontend frameworks and component-driven architecture.',
      },
      {
        title: 'Design Systems',
        description: 'Creating reusable UI systems and scalable component libraries aligned with product consistency.',
      },
      {
        title: 'UX & Accessibility',
        description: 'Designing inclusive, intuitive experiences with accessibility-first frontend development.',
      },
      {
        title: 'Motion & Interaction',
        description: 'Enhancing user experiences through thoughtful animation and interactive feedback.',
      },
      {
        title: 'Research & Prototyping',
        description: 'Transforming user insights into wireframes, prototypes, and validated interface solutions.',
      },
      {
        title: 'Cross-Functional Collaboration',
        description: 'Bridging the gap between design and engineering to streamline product development.',
      },
      {
        title: 'Performance Optimization',
        description: 'Improving frontend speed and responsiveness through modern optimization techniques.',
      },
      {
        title: 'API Integration & Data Handling',
        description: 'Connecting frontend applications with dynamic data and scalable state management.',
      },
      {
        title: 'Product Thinking & User-Centered Design',
        description:
          'Balancing user needs, business goals, and technical feasibility to create effective digital experiences.',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    id="portfolio"
    title="Case Studies"
    subtitle="Explore how I combine deep user research with clean, responsive code to solve real-world problems."
    isReversed
    items={[
      {
        title: 'Description:',
        description:
          'Developed a comprehensive brand identity for a tech startup, Tech Innovators, specializing in disruptive innovations. The goal was to convey a modern yet approachable image that resonated with both corporate clients and tech enthusiasts.',
      },
      {
        title: 'Role:',
        description:
          'Led the entire branding process from concept to execution. Created a dynamic logo that symbolized innovation, selected a vibrant color palette, and I designed corporate stationery, website graphics, and social media assets.',
      },
    ]}
    image={{
      src: PhoneMockupImage,
      alt: 'Tech Design Image',
    }}
    callToAction={{
      text: 'View Case Study & Prototype',
      icon: 'tabler:chevron-right',
      href: '/creditwise-mobile-app-case-study',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">CreditWise Mobile App</h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent={true}
    items={[
      {
        title: 'Description:',
        description:
          'Designed as a capstone project for the Google UX Design Professional Certificate, CreditWise is a mobile application aimed at demystifying personal finance for young adults. The goal was to build an intuitive, stress-free interface that helps users track their credit score, set financial goals, and learn smart saving habits through gamified bite-sized lessons.',
      },
      {
        title: 'Role:',
        description: `Led the end-to-end product design process. Conducted primary user research and competitive audits, designed user flows, and created low-to-high fidelity wireframes in Figma. Developed an interactive, high-fidelity mobile prototype demonstrating seamless transitions and dynamic state changes to simulate a live React Native environment.`,
      },
    ]}
    image={{
      src: PhoneMockupImage,
      alt: 'Art and Music Poster Image',
    }}
    callToAction={{
      text: 'View Live Site / GitHub Repository',
      icon: 'tabler:chevron-right',
      href: 'creditwise-landing-page-case-study',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">CreditWise Landing Page</h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="Client testimonials"
    subtitle="Discover what clients have to say about their experiences working with me."
    testimonials={[
      {
        testimonial: `Max is the best web designer!  He listens to you as a client and is patient in making sure your vision comes to life!  He is a unique blend of creativity and technical expertise to bring your website from a rough idea to a beautiful custom website! If you’re reading this review and you need a website for yourself or your organization, hire Max now!`,
        name: 'Ervin McWilson',
        job: 'Euntrepreneur, TEDx Speaker',
        image: {
          src: ErvinAvatar,
          alt: 'Ervin McWilson Image',
        },
      },
      {
        testimonial: `Easy to work with,and top quality results. Would highly recommend to anyone looking for web design, thanks!`,
        name: 'David Kapelkin',
        job: 'Owner, Sac HVAC',
        image: {
          src: DavidAvatar,
          alt: 'David K Image',
        },
      },
      {
        testimonial: `Amazing work start to finish, Max went the extra mile! Would highly recommend`,
        name: 'Iliya Z',
        job: 'Owner, Fund Finders',
        image: {
          src: IliyaAvatar,
          alt: 'Ilya Z Image',
        },
      },
      {
        testimonial: `I was satisfied with the whole process from A-Z. Very professional and quick. I highly recommend these services.`,
        name: 'Mike Rybin',
        job: 'Owner, Cali-Precision',
        image: {
          src: MikeAvatar,
          alt: 'Mike Rybin Image',
        },
      },
      {
        testimonial: `Max is the absolute best. He’s responsive, punctual, detail oriented, efficient, honest, and can do pretty much anything you need. Seriously. He really understood what my company needed what style to choose, from the first meeting. He does excellent job and I’d recommend him to anyone.`,
        name: 'Dan S',
        job: 'Owner, Caliwoods Inc',
        image: {
          src: DanAvatar,
          alt: 'Dan S Image',
        },
      },
      {
        testimonial: `Max designed and built my website, I'd say he did an outstanding job. Good communication and even designed a logo for my company.`,
        name: 'Eugene Yelenskiy',
        job: 'Owner, Voltage Solutions Inc',
        image: {
          src: EugeneAvatar,
          alt: 'Laura Simmons Image',
        },
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <!-- <CallToAction
    title="Let's create together"
    subtitle="Ready to transform your vision into captivating designs?"
    actions={[
      {
        variant: 'primary',
        text: 'Hire me',
        href: '/',
      },
    ]}
  /> -->
  <!-- Contact Widget **************** -->
  <ContactUs
    id="contact"
    title="Get in touch"
    subtitle="Have an exciting product vision, a complex design system that needs engineering, or a front-end role you're looking to fill? Drop me a message and let's discuss how we can work together."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
    ]}
    textarea={{
      label: 'Tell me about your project / role',
    }}
    disclaimer={{
      label: 'By submitting this form, you agree to share your contact details with me so I can reply to your inquiry.',
    }}
    description="I typically reply within 24–48 business hours. You can also connect with me directly via LinkedIn."
    button="Send Message"
  />
</Layout>
